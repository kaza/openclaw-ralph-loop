# Required
OPENCLAW_GATEWAY_TOKEN=replace-me
RALPH_SESSION_KEY=agent:main:supervisor:ralph-loop

# Optional
RALPH_GATEWAY_URL=http://127.0.0.1:18789
RALPH_LOG_PATH=./ralph-loop.log
RALPH_LOCK_PATH=./ralph-loop.lock
RALPH_TARGET=2
RALPH_STALE_MS=600000
RALPH_INTERVAL_MS=60000
RALPH_LABEL_PREFIX=ralph-worker-

# Default worker profile
RALPH_SPAWN_RUNTIME=subagent
RALPH_SPAWN_AGENT_ID=codex-reasoning
RALPH_SPAWN_MODEL=codex
RALPH_SPAWN_THINKING=low
RALPH_SPAWN_MODE=run
RALPH_SPAWN_RUN_TIMEOUT_SECONDS=300
RALPH_SPAWN_TIMEOUT_SECONDS=0
RALPH_SPAWN_CLEANUP=keep

# Example task
RALPH_WORKER_TASK=Write exactly one short 4-line poem and nothing else.
